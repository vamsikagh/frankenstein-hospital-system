    {
      "uri": "/agent-generated",
      "name": "Agent Generated Result",
      "description": "Success screen showing the newly generated agent from a natural language prompt",
      "examples": [
        {
          "name": "Agent Created Successfully",
          "description": "Celebration state for a newly generated agent",
          "data": {
            "success": true,
            "message": "Agent 'ICU Tachycardia Alerter' created successfully from natural language",
            "prompt": "alert the doctor when a patient's heartbeat crosses 120 bpm",
            "matchedTemplate": "vitals-monitoring",
            "templateLabel": "Vitals Monitor",
            "agent": {
              "id": "agent_new_123",
              "templateId": "vitals-monitoring",
              "name": "ICU Tachycardia Alerter",
              "description": "alert the doctor when a patient's heartbeat crosses 120 bpm",
              "status": "active",
              "alertCount": 0,
              "createdAt": "2026-07-17T14:55:00.000Z",
              "config": {
                "thresholds": {
                  "heartRateHigh": 120
                },
                "alertRules": [
                  {
                    "condition": "heartRate > 120",
                    "severity": "warning",
                    "message": "Elevated heart rate detected: {value} bpm for patient {patientId}"
                  }
                ],
                "checkIntervalSeconds": 30,
                "resourceEndpoint": "fhir://patients/{patientId}/observations"
              }
            }
          }
        }
      ],
      "tags": ["agent", "creation", "success"]
    },
