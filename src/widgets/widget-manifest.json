    {
      "uri": "/agent-detail",
      "name": "Agent Configuration Detail",
      "description": "Detailed view of an agent's configured thresholds and rules",
      "examples": [
        {
          "name": "Active Vitals Agent Configuration",
          "description": "Vitals Monitoring agent thresholds and rules",
          "data": {
            "success": true,
            "agent": {
              "id": "agent_vitals_1",
              "templateId": "vitals-monitoring",
              "name": "ICU Vitals Alerter",
              "description": "Monitors heart rate and SpO2 in the ICU ward",
              "status": "active",
              "createdAt": "2026-07-17T14:00:00.000Z",
              "alertCount": 8,
              "config": {
                "thresholds": {
                  "heartRateHigh": 120,
                  "heartRateLow": 50,
                  "spo2Low": 90,
                  "temperatureHigh": 39.0
                },
                "alertRules": [
                  {
                    "condition": "heartRate > 120",
                    "severity": "warning",
                    "message": "Elevated heart rate detected: {value} bpm for patient {patientId}"
                  },
                  {
                    "condition": "spo2 < 90",
                    "severity": "critical",
                    "message": "CRITICAL: Hypoxemia — SpO2 at {value}% for patient {patientId}"
                  }
                ],
                "checkIntervalSeconds": 30,
                "resourceEndpoint": "fhir://patients/{patientId}/observations"
              }
            }
          }
        }
      ],
      "tags": ["agent", "detail", "config"]
    },
