# Frankenstein — Environment Configuration

# ── Server ────────────────────────────────────────────────────
NITRO_LOG_LEVEL=info
NITROSTACK_APP_MODE=openai

# MCP_TRANSPORT_TYPE: stdio (dev) | http | dual (production)
# Defaults to 'stdio' in dev, 'dual' in production.
MCP_TRANSPORT_TYPE=dual
PORT=3000
HOST=0.0.0.0
ENABLE_CORS=true

# ── API Keys ──────────────────────────────────────────────────
# Simple API-key guard. In dev mode, requests without a key are allowed
# (NitroStudio connects via stdio). Set API_KEY_1 to enforce in prod.
# API_KEY_1=frankenstein-local-dev-key

# ── LLM (for prompt → AgentSpec parsing) ──────────────────────
# Leave blank to use the keyword-matching fallback (no LLM call).
# Supports OpenAI gpt-4o-mini or any OpenAI-compatible endpoint.
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# For Gemini via OpenAI-compatible gateway:
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.0-flash
